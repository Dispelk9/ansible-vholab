# Auto-generated by ansible-vholab (diode_server role). Do not edit by hand
# on the target host - edit host_vars/vhohetzner1/vault.yml /
# group_vars/vhodockers.yml and re-run netbox_discovery_deploy.yml instead.
#
# Variable names below were verified directly against the fetched
# docker-compose.yaml + upstream sample.env for diode_server_compose_ref
# (see defaults/main.yml - pinned to an exact commit, not the floating
# "release" branch, specifically because this schema has already drifted
# out from under this file once). If you re-pin to a newer ref, re-diff
# both files before trusting this template again:
# https://github.com/netboxlabs/diode/blob/{{ diode_server_compose_ref }}/diode-server/docker/docker-compose.yaml
# https://github.com/netboxlabs/diode/blob/{{ diode_server_compose_ref }}/diode-server/docker/sample.env

# --- Redis (Diode's own queue - not NetBox's redis/redis-cache) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD={{ diode_redis_password }}

# --- Postgres bootstrap superuser (creates the diode/hydra roles+DBs below
# via the init script baked into the postgres service's command - this is
# NOT the same account Diode/Hydra connect with day-to-day). Must be a
# different username than DIODE_POSTGRES_USER below - the init script
# connects as this user and then CREATEs the diode/hydra roles, which fails
# if they're the same name. Password reuses diode_postgres_password rather
# than adding yet another vault secret - this postgres instance isn't
# reachable outside the diode compose project's internal network anyway.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER={{ diode_postgres_bootstrap_user }}
POSTGRES_PASSWORD={{ diode_postgres_password }}

# --- Diode's own app DB (reconciler state) - separate role+database the
# bootstrap superuser above creates on first init ---
DIODE_POSTGRES_DB_NAME={{ diode_postgres_db }}
DIODE_POSTGRES_USER={{ diode_postgres_user }}
DIODE_POSTGRES_PASSWORD={{ diode_postgres_password }}

# --- Hydra's own DB (OAuth2 state) - same pattern, separate role+database ---
HYDRA_POSTGRES_DB_NAME={{ hydra_postgres_db }}
HYDRA_POSTGRES_USER={{ hydra_postgres_user }}
HYDRA_POSTGRES_PASSWORD={{ hydra_postgres_password }}

# --- gRPC (ingester/reconciler's own internal port; nginx fronts this on
# DIODE_NGINX_PORT for clients outside the diode compose project) ---
GRPC_PORT=8081
DIODE_NGINX_PORT={{ diode_nginx_bind_port }}

# --- Ory Hydra (OAuth2 server) ---
HYDRA_STRATEGIES_ACCESS_TOKEN={{ hydra_strategies_access_token }}
HYDRA_STRATEGIES_REFRESH_TOKEN={{ hydra_strategies_refresh_token }}
HYDRA_STRATEGIES_JWT_SCOPE_CLAIM={{ hydra_strategies_jwt_scope_claim }}
HYDRA_TTL_ACCESS_TOKEN={{ hydra_ttl_access_token }}
HYDRA_OIDC_SUBJECT_IDENTIFIERS_SUPPORTED_TYPES={{ hydra_oidc_subject_identifiers_supported_types }}
# Set to the "hydra" service name (not upstream sample.env's 127.0.0.1
# default) so introspection from diode-auth/hydra-migrate, which happens
# container-to-container on the shared docker_discovery_network_name
# network, can actually resolve the issuer for OIDC discovery.
HYDRA_URLS_SELF_ISSUER={{ hydra_urls_self_issuer }}
HYDRA_SECRETS_SYSTEM_0={{ hydra_secrets_system_0 }}

# --- Auth (diode-auth service fronts Hydra for introspection) ---
AUTH_HTTP_PORT={{ auth_http_port }}
OAUTH2_PUBLIC_SERVER_URL=http://hydra:4444
OAUTH2_ADMIN_SERVER_URL=http://hydra:4445
# Reconciler talks to diode-auth directly on the shared docker network, not
# through the nginx front door (that's only for traffic entering from
# outside the compose project - see docker-compose.override.yml.j2).
DIODE_AUTH_TOKEN_URL=http://diode-auth:{{ auth_http_port }}/token

# --- OAuth2 client Diode's reconciler uses to call back into NetBox's
# plugin API. Registration of this (and the netbox-to-diode / orb-agent
# ingest clients) happens via oauth2/client/client-credentials.json - see
# client-credentials.json.j2 - NOT via env vars; these two are only what
# the reconciler itself reads to authenticate as that already-registered
# client. ---
DIODE_TO_NETBOX_CLIENT_ID={{ diode_to_netbox_client_id }}
DIODE_TO_NETBOX_CLIENT_SECRET={{ diode_to_netbox_client_secret }}

# --- Reconciler -> NetBox callback ---
NETBOX_DIODE_PLUGIN_API_BASE_URL={{ netbox_diode_plugin_api_base_url }}
NETBOX_DIODE_PLUGIN_SKIP_TLS_VERIFY={{ netbox_diode_plugin_skip_tls_verify | string | lower }}
MIGRATION_ENABLED=true
ENABLE_GRAPH_DB=false

# --- Logging / error reporting ---
LOGGING_LEVEL={{ diode_logging_level }}
SENTRY_DSN={{ diode_sentry_dsn }}

# --- Telemetry (off by default - flip to prometheus/otlp/console if wired up) ---
TELEMETRY_METRICS_EXPORTER=none
TELEMETRY_METRICS_PORT=9090
TELEMETRY_TRACES_EXPORTER={{ diode_telemetry_traces_exporter }}
TELEMETRY_ENVIRONMENT={{ diode_telemetry_environment }}
