# Example only - the real .env (with real secrets) is generated by the
# diode_server Ansible role from host_vars/vhohetzner1/vault.yml and is not
# checked into git. This file documents the shape for manual/ad-hoc use.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=CHANGE-ME

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB_NAME={{ diode_postgres_db }}
POSTGRES_USER={{ diode_postgres_user }}
POSTGRES_PASSWORD=CHANGE-ME

GRPC_PORT=8081
DIODE_NGINX_PORT={{ diode_nginx_bind_port }}

HTTP_PORT=8080
OAUTH2_PUBLIC_SERVER_URL=http://hydra:4444
OAUTH2_ADMIN_SERVER_URL=http://hydra:4445
DIODE_AUTH_TOKEN_URL=http://{{ diode_frontend_service | default(diode_frontend_service_fallback) }}:8080/auth/oauth2/token

DIODE_TO_NETBOX_CLIENT_ID={{ diode_to_netbox_client_id }}
DIODE_TO_NETBOX_CLIENT_SECRET=CHANGE-ME
NETBOX_TO_DIODE_CLIENT_ID={{ netbox_to_diode_client_id }}
NETBOX_TO_DIODE_CLIENT_SECRET=CHANGE-ME

NETBOX_DIODE_PLUGIN_API_BASE_URL={{ netbox_diode_plugin_api_base_url }}
NETBOX_DIODE_PLUGIN_SKIP_TLS_VERIFY={{ netbox_diode_plugin_skip_tls_verify | string | lower }}
MIGRATION_ENABLED=true
ENABLE_GRAPH_DB=false

TELEMETRY_METRICS_EXPORTER=none
TELEMETRY_METRICS_PORT=9090
