# Auto-generated by ansible-vholab. Layered on top of the unmodified,
# fetched docker-compose.yaml (see fetch_compose.yml) - this file is the
# only thing we author ourselves for the Diode server stack.
#
# 1. Re-points every service's implicit "default" network at our shared,
#    externally-managed bridge network, so NetBox (a different Compose
#    project) can resolve Diode's containers by name and vice versa -
#    without needing to know/guess every individual service name.
# 2. Publishes the nginx front door on the host so Orb Agent (which runs
#    with network_mode: host) and any external Diode Agents can reach it.
# 3. Fixes an upstream bug in the pinned docker-compose.yaml: diode-auth-bootstrap's
#    command runs /etc/config/oauth2/client/bootstrap-clients.sh, but
#    Dockerfile.auth bakes the script at /etc/config/oauth2/bootstrap-clients.sh
#    (no "client" subdir) - and our own oauth2/client volume mount (see
#    client-credentials.json.j2) shadows that subdir with just our
#    credentials file, so the script genuinely isn't there. Without this
#    override the container crash-loops (exit 1, restart, repeat) forever.
# 4. Pins ingress-nginx and redis to an exact tag - the fetched
#    docker-compose.yaml hardcodes both as ":latest" with no override env
#    var (unlike diode-ingester/reconciler/auth, which read ${DIODE_TAG} -
#    see env.j2). This is the only place they can be pinned without
#    editing the fetched file in place.
#
# Upstream service healthchecks are sparse (only postgres has one as of
# this writing) - rather than guess at container-exec healthchecks that may
# not even work on distroless/scratch-based Go images, readiness is gated
# from the Ansible side with a plain TCP check (see tasks/deploy.yml).
networks:
  default:
    name: "{{ docker_discovery_network_name }}"
    external: true

services:
  "{{ diode_frontend_service }}":
    image: "{{ diode_nginx_image }}"
    ports:
      - "{{ diode_nginx_bind_ip }}:{{ diode_nginx_bind_port }}:{{ diode_nginx_internal_port }}"

  redis:
    image: "{{ diode_redis_image }}"

  diode-auth-bootstrap:
    command: ["/bin/sh", "/etc/config/oauth2/bootstrap-clients.sh"]
