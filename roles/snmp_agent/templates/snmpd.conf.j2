# Auto-generated by ansible-vholab (snmp_agent role). Do not edit by hand on
# the target host - edit group_vars/Hetzner/vars.yml (or vault.yml for the
# passphrases) and re-run update_hetzner.yml instead.
#
# Only exists so roles/orb_agent's snmp_discovery backend can poll this host
# for Device/Interface/Prefix inventory - see
# roles/orb_agent/templates/agent.yaml.j2.

# Bound explicitly to the private-network IP, never 0.0.0.0 - this host also
# carries a public IPv4/IPv6 address (see hetzner_terraform/main.tf), and
# SNMP has no business ever being reachable from the internet (a classic
# reflection/amplification DDoS vector, and a target for community-string
# brute-forcing). Defense in depth: even if the Hetzner Cloud Firewall rule
# (hetzner_terraform/firewall.tf, scoped to vhodockers' IP only) were ever
# misconfigured or removed, snmpd itself still wouldn't be listening on the
# public interface at all.
agentAddress udp:{{ snmp_agent_bind_ip }}:{{ orb_snmp_port }}

# SNMPv3 authPriv only - no v1/v2c community string is defined anywhere in
# this file, so there is no cleartext-over-the-wire credential to sniff even
# on the private network. Read-only ("priv" with no "rw"/"rwuser" line
# anywhere) - this user can observe but never write/change device config.
rouser {{ orb_snmp_username }} priv
