#!/bin/bash
# Auto-generated by ansible-vholab (netbox role). Do not edit by hand on the
# target host - edit netbox_db_backup_* in group_vars/vhodockers.yml (or
# roles/netbox/defaults/main.yml) and re-run netbox_deploy.yml instead.
set -euo pipefail

NETBOX_DIR="{{ netbox_install_dir }}/netbox-docker"
BACKUP_DIR="{{ netbox_db_backup_dir }}"
DATE=$(date +%F_%H-%M)

# Read the actual DB name/user netbox-docker is configured with, rather than
# hardcoding its upstream defaults here - roles/netbox's own secrets task
# never rewrites POSTGRES_DB/POSTGRES_USER (only POSTGRES_PASSWORD), so
# these always track netbox-docker's own env/postgres.env.
POSTGRES_DB=$(grep -m1 '^POSTGRES_DB=' "$NETBOX_DIR/env/postgres.env" | cut -d= -f2-)
POSTGRES_USER=$(grep -m1 '^POSTGRES_USER=' "$NETBOX_DIR/env/postgres.env" | cut -d= -f2-)

FILENAME="$BACKUP_DIR/netbox_${POSTGRES_DB}_${DATE}.sql.gz"
TMP_FILENAME="${FILENAME}.partial"

cleanup() {
  rm -f "$TMP_FILENAME"
}
trap cleanup ERR

cd "$NETBOX_DIR"

# `docker compose exec` (not `docker exec <container-name>`) so this
# resolves the "postgres" service correctly regardless of whether
# netbox_discovery_deploy.yml has layered docker-compose.diode.yml on top
# of this project - same -f flags roles/netbox's own pull/up tasks use. No
# -h/password needed: this runs inside the container over its local socket,
# which the official postgres image trusts for local connections.
docker compose -f docker-compose.yml -f docker-compose.override.yml exec -T postgres \
  pg_dump -U "$POSTGRES_USER" "$POSTGRES_DB" | gzip > "$TMP_FILENAME"

# Verify the dump is actually valid before trusting it (and before pruning
# any older backups below) - catches a truncated/corrupt dump from a
# mid-stream pg_dump failure that `set -o pipefail` alone wouldn't always
# leave in an obviously-broken state.
gzip -t "$TMP_FILENAME"
if [ ! -s "$TMP_FILENAME" ]; then
  echo "netbox-db-backup: dump is empty, refusing to keep it" >&2
  exit 1
fi

mv "$TMP_FILENAME" "$FILENAME"

# Prune backups older than the retention window - only after a successful,
# verified backup above.
find "$BACKUP_DIR" -name 'netbox_*.sql.gz' -mtime +{{ netbox_db_backup_retention_days }} -delete
