# Auto-generated by ansible-vholab. No official compose file is published by
# netboxlabs/orb-agent (only `docker run`/`podman run` examples in their
# docs as of this writing) - this is hand-authored to match those.
#
# network_mode: host is required for raw network scanning (nmap SYN/etc.)
# per upstream docs; NET_RAW/NET_ADMIN are the least-privileged capabilities
# their own docker example implies (full `--privileged` is only shown for
# rootless Podman, not plain Docker).
services:
  orb-agent:
    image: "{{ orb_image }}:{{ orb_image_tag }}"
    container_name: orb-agent
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_RAW
      - NET_ADMIN
    env_file:
      - .env
    volumes:
      - "{{ orb_dir }}/agent.yaml:/opt/orb/agent.yaml:ro"
      - "{{ orb_dir }}/data:/opt/orb"
    command: ["run", "-c", "/opt/orb/agent.yaml"]
