# Managed by ansible-vholab (netbox_diode_plugin role). Appends to (never
# replaces) the PLUGINS / PLUGINS_CONFIG already defined earlier in this
# file, so any other plugins configured here by hand are left untouched.
#
# Does NOT assume PLUGINS/PLUGINS_CONFIG already exist in this file - that
# assumption broke a live, previously-4-months-healthy NetBox instance
# (NameError: name 'PLUGINS' is not defined) because this deployment's own
# configuration/plugins.py doesn't define them itself. Defining them here
# if missing is safe either way: a no-op when they already exist elsewhere
# in the file, load-bearing when they don't.
try:
    PLUGINS
except NameError:
    PLUGINS = []
try:
    PLUGINS_CONFIG
except NameError:
    PLUGINS_CONFIG = {}

# netbox_to_diode_client_secret is deliberately NOT set here. The plugin's
# own documented default is to read it from a Docker secret file at
# /run/secrets/netbox_to_diode (secrets_path + netbox_to_diode_client_secret_name
# defaults) - see tasks/secrets.yml and docker-compose.diode.yml.j2. This
# keeps the shared secret out of configuration/plugins.py entirely.
#
# This block is preserved (via git stash) across netbox_deploy.yml re-runs,
# which use the plain upstream image - one that never has this package
# installed at all (only the custom Diode-plugin image, built separately,
# does). Blindly appending the module name to PLUGINS regardless crashed
# NetBox outright on the plain image (Django fails to import a plugin
# module that doesn't exist in that image - confirmed live: "exited (1)"
# right after the plain-image `up -d`, immediately following a run where
# this same block worked fine on the custom image). Checking the package is
# actually importable first makes this block safe on BOTH images: a no-op
# on the plain one, load-bearing on the custom one.
try:
    import importlib.util as _diode_importutil
    _diode_plugin_importable = _diode_importutil.find_spec("{{ diode_plugin_module_name }}") is not None
except ImportError:
    _diode_plugin_importable = False

if _diode_plugin_importable:
    if "{{ diode_plugin_module_name }}" not in PLUGINS:
        PLUGINS.append("{{ diode_plugin_module_name }}")

    PLUGINS_CONFIG.setdefault("{{ diode_plugin_module_name }}", {})
    PLUGINS_CONFIG["{{ diode_plugin_module_name }}"].update({
        "diode_target_override": "{{ diode_plugin_diode_target }}",
        "diode_username": "{{ diode_plugin_username }}",
        "netbox_to_diode_client_id": "{{ netbox_to_diode_client_id }}",
    })
